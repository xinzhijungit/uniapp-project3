{
  "version": 2,
  "name": "xian-police-platform",
  "builds": [
    {
      "src": "server/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "dist/build/h5/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/build/h5/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/build/h5/index.html"
    }
  ]
}
